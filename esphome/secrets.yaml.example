# Copy to secrets.yaml and fill in. ESPHome reads !secret values from here.
# (secrets.yaml is gitignored — never commit real credentials.)

wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# Generate a key in the ESPHome dashboard, or with:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_key_steamdeck: "base64-32-byte-key-here=="

ota_password_steamdeck: "pick-an-ota-password"
